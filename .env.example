# Required: path to your OMOP DuckDB database file
DB_PATH=/path/to/omop.duckdb

# Required: path to the omcp_server checkout (used to launch the MCP server)
OMCP_SERVER_DIR=/path/to/omcp_server

MILVUS_HOST="localhost"
MILVUS_PORT="19530"
MILVUS_COLLECTION="fastomop_vocab"

# Provider API Keys (only set what you use)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Azure-specific (if using Azure)
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Optional: Langfuse observability (off by default)
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_SECRET_KEY=sk-lf-xxx

# Optional overrides
# MCP_COMMAND=python custom_mcp.py
