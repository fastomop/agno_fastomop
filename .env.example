# Base configuration
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx

MILVUS_HOST="localhost"
MILVUS_PORT="19530"
MILVUS_COLLECTION="fastomop_vocab"

# Provider API Keys (only set what you use)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Azure-specific (if using Azure)
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# OMCP MCP Server (required)
# Path to the OMCP server directory and the full command to start it
OMCP_SERVER_PATH=/path/to/omcp_server
MCP_COMMAND="uv run --directory /path/to/omcp_server python src/omcp/main.py"

# Ollama (required if using Ollama models)
OLLAMA_HOST=http://localhost:11434

# OMOP Database
DB_TYPE=duckdb
DB_PATH=/path/to/omop.duckdb
DB_READ_ONLY=true
CDM_SCHEMA=omop_gold
VOCAB_SCHEMA=athena

# HPC Image Fetching (required for imaging pipeline)
# HPC_HOST=<your-hpc-ip>
# HPC_USER=<your-ssh-username>
# HPC_SSH_KEY_PATH=~/.ssh/id_rsa_hpc
